# Copy this file to .env.local and fill in your own values

# MongoDB connection string (MongoDB Atlas or local MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/mpl?retryWrites=true&w=majority

# Admin login password (choose a strong password)
ADMIN_PASSWORD=change-this-password

# Secret used to sign the admin login session cookie (any long random string)
SESSION_SECRET=change-this-to-a-long-random-string
