# Copy this file to .env.local and fill in your own values

# MongoDB connection string (MongoDB Atlas or local MongoDB)
MONGODB_URI=mongodb+srv://_db_user:E6@cluster0.w6goluw.mongodb.net/

# Admin login password (choose a strong password)
ADMIN_PASSWORD=pad

# Secret used to sign the admin login session cookie (any long random string)
SESSION_SECRET=change--random-string

# Cloudflare R2 (S3-compatible object storage) for profile pictures, CNIC
# images, and fee receipts. The bucket should be kept PRIVATE -- the admin
# dashboard reads files via short-lived signed URLs, not public links.
# Account ID and API token are in the Cloudflare dashboard under R2 > Manage API Tokens.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
